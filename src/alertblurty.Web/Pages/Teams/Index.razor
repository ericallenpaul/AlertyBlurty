@page "/teams"
@attribute [Authorize]
@inject ITeamApiService TeamApi
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Teams - AlertyBlurty</PageTitle>

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col">
            <h2><i class="bi bi-people"></i> Teams</h2>
            <p class="text-muted">Manage on-call teams and schedules</p>
        </div>
        <div class="col-auto">
            <AuthorizeView Roles="SuperAdmin,Admin">
                <button class="btn btn-primary" @onclick="ShowCreateModal">
                    <i class="bi bi-plus-circle"></i> Create Team
                </button>
            </AuthorizeView>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-3">Loading teams...</p>
        </div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle"></i> @errorMessage
            <button type="button" class="btn-close" @onclick="() => errorMessage = string.Empty"></button>
        </div>
    }
    else if (teams == null || !teams.Any())
    {
        <div class="card shadow">
            <div class="card-body text-center py-5">
                <i class="bi bi-people text-muted" style="font-size: 4rem;"></i>
                <h4 class="mt-3">No Teams Yet</h4>
                <p class="text-muted">Create your first team to get started with on-call management</p>
                <AuthorizeView Roles="SuperAdmin,Admin">
                    <button class="btn btn-primary" @onclick="ShowCreateModal">
                        <i class="bi bi-plus-circle"></i> Create First Team
                    </button>
                </AuthorizeView>
            </div>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var team in teams)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card shadow h-100">
                        <div class="card-header bg-primary text-white">
                            <h5 class="mb-0">@team.Name</h5>
                        </div>
                        <div class="card-body">
                            @if (!string.IsNullOrEmpty(team.Description))
                            {
                                <p class="text-muted">@team.Description</p>
                            }

                            <div class="mb-3">
                                <small class="text-muted">Requires Admin Approval for Swaps</small>
                                <p class="mb-0">
                                    @if (team.RequireAdminApprovalForSwaps)
                                    {
                                        <span class="badge bg-warning text-dark">Yes</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">No</span>
                                    }
                                </p>
                            </div>

                            <div class="d-flex justify-content-between align-items-center">
                                <span class="text-muted">
                                    <i class="bi bi-people"></i> @(team.Members?.Count ?? 0) member(s)
                                </span>
                                <button class="btn btn-sm btn-outline-primary" @onclick="() => ViewTeam(team.Id)">
                                    <i class="bi bi-eye"></i> View
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="alert alert-success alert-dismissible fade show mt-3">
            <i class="bi bi-check-circle"></i> @successMessage
            <button type="button" class="btn-close" @onclick="() => successMessage = string.Empty"></button>
        </div>
    }
</div>

<!-- Create Team Modal -->
@if (showCreateModal)
{
    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">Create New Team</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="HideCreateModal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Team Name *</label>
                        <input type="text" class="form-control" @bind="newTeamName" placeholder="e.g., Backend Team" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea class="form-control" @bind="newTeamDescription" rows="3" placeholder="Brief description of this team's responsibilities"></textarea>
                    </div>
                    <div class="mb-3">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" @bind="requireAdminApproval" id="requireApproval">
                            <label class="form-check-label" for="requireApproval">
                                Require admin approval for shift swaps
                            </label>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="HideCreateModal">Cancel</button>
                    <button type="button" class="btn btn-primary" @onclick="CreateTeam" disabled="@isCreating">
                        @if (isCreating)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                            <span>Creating...</span>
                        }
                        else
                        {
                            <span><i class="bi bi-check"></i> Create Team</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool isLoading = true;
    private bool isCreating = false;
    private bool showCreateModal = false;
    private string errorMessage = string.Empty;
    private string successMessage = string.Empty;

    private List<TeamDto>? teams;
    private Guid currentOrganizationId;

    // Create modal fields
    private string newTeamName = string.Empty;
    private string newTeamDescription = string.Empty;
    private bool requireAdminApproval = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadTeams();
            StateHasChanged();
        }
    }

    private async Task LoadTeams()
    {
        try
        {
            // Get current user's organization ID from auth state
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var orgIdClaim = authState.User.FindFirst("OrganizationId");

            if (orgIdClaim != null && Guid.TryParse(orgIdClaim.Value, out var orgId))
            {
                currentOrganizationId = orgId;
                teams = await TeamApi.GetByOrganizationAsync(currentOrganizationId);
            }
            else
            {
                errorMessage = "Unable to determine your organization";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load teams: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ShowCreateModal()
    {
        showCreateModal = true;
        newTeamName = string.Empty;
        newTeamDescription = string.Empty;
        requireAdminApproval = false;
        errorMessage = string.Empty;
    }

    private void HideCreateModal()
    {
        showCreateModal = false;
    }

    private async Task CreateTeam()
    {
        if (string.IsNullOrWhiteSpace(newTeamName))
        {
            errorMessage = "Please enter a team name";
            return;
        }

        isCreating = true;
        errorMessage = string.Empty;

        try
        {
            var request = new alertblurty.Models.Requests.Teams.CreateTeamRequest
            {
                Name = newTeamName,
                Description = newTeamDescription,
                RequireAdminApprovalForSwaps = requireAdminApproval
            };

            var result = await TeamApi.CreateAsync(request);

            if (result != null)
            {
                successMessage = $"Team '{newTeamName}' created successfully!";
                HideCreateModal();
                await LoadTeams();
            }
            else
            {
                errorMessage = "Failed to create team";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error creating team: {ex.Message}";
        }
        finally
        {
            isCreating = false;
        }
    }

    private void ViewTeam(Guid teamId)
    {
        Navigation.NavigateTo($"/teams/{teamId}");
    }
}
