@page "/dashboard"
@attribute [Authorize]
@inject IIncidentApiService IncidentApi
@inject ITeamApiService TeamApi
@inject IUserApiService UserApi
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation

<PageTitle>Dashboard - AlertyBlurty</PageTitle>

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col">
            <h2><i class="bi bi-speedometer2"></i> Dashboard</h2>
            <p class="text-muted">Welcome back, @userName</p>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-3">Loading dashboard...</p>
        </div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">
            <i class="bi bi-exclamation-triangle"></i> @errorMessage
        </div>
    }
    else
    {
        <!-- Summary Cards -->
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card border-danger">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-muted mb-1">Active Incidents</h6>
                                <h2 class="mb-0">@activeIncidentsCount</h2>
                            </div>
                            <div class="text-danger">
                                <i class="bi bi-exclamation-triangle" style="font-size: 2.5rem;"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card border-warning">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-muted mb-1">Acknowledged</h6>
                                <h2 class="mb-0">@acknowledgedIncidentsCount</h2>
                            </div>
                            <div class="text-warning">
                                <i class="bi bi-check-circle" style="font-size: 2.5rem;"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card border-info">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-muted mb-1">My Teams</h6>
                                <h2 class="mb-0">@teamsCount</h2>
                            </div>
                            <div class="text-info">
                                <i class="bi bi-people" style="font-size: 2.5rem;"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card border-success">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-muted mb-1">Resolved Today</h6>
                                <h2 class="mb-0">@resolvedTodayCount</h2>
                            </div>
                            <div class="text-success">
                                <i class="bi bi-check2-circle" style="font-size: 2.5rem;"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Active Incidents Table -->
        <div class="row">
            <div class="col-12">
                <div class="card shadow">
                    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="bi bi-exclamation-triangle"></i> Active Incidents</h5>
                        <button class="btn btn-light btn-sm" @onclick="NavigateToIncidents">
                            View All <i class="bi bi-arrow-right"></i>
                        </button>
                    </div>
                    <div class="card-body">
                        @if (incidents == null || !incidents.Any())
                        {
                            <div class="text-center py-4">
                                <i class="bi bi-check-circle text-success" style="font-size: 3rem;"></i>
                                <p class="mt-3 text-muted">No active incidents. All systems operational!</p>
                            </div>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-hover">
                                    <thead>
                                        <tr>
                                            <th>Severity</th>
                                            <th>Title</th>
                                            <th>Status</th>
                                            <th>Team</th>
                                            <th>Created</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var incident in incidents.Take(10))
                                        {
                                            <tr>
                                                <td>
                                                    <span class="badge @GetSeverityBadgeClass(incident.Severity)">
                                                        @GetSeverityText(incident.Severity)
                                                    </span>
                                                </td>
                                                <td>@incident.TriggerName</td>
                                                <td>
                                                    <span class="badge @GetStatusBadgeClass(incident.Status)">
                                                        @incident.Status.ToString()
                                                    </span>
                                                </td>
                                                <td>@incident.TeamName</td>
                                                <td>@incident.FirstOccurrenceUtc.ToLocalTime().ToString("MMM dd, yyyy HH:mm")</td>
                                                <td>
                                                    <button class="btn btn-sm btn-outline-primary" @onclick="() => ViewIncident(incident.Id)">
                                                        <i class="bi bi-eye"></i> View
                                                    </button>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Recent Activity -->
        <div class="row mt-4">
            <div class="col-12">
                <div class="card shadow">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0"><i class="bi bi-clock-history"></i> Recent Activity</h5>
                    </div>
                    <div class="card-body">
                        @if (incidents == null || !incidents.Any())
                        {
                            <p class="text-muted mb-0">No recent activity to display.</p>
                        }
                        else
                        {
                            <ul class="list-unstyled mb-0">
                                @foreach (var incident in incidents.OrderByDescending(i => i.FirstOccurrenceUtc).Take(5))
                                {
                                    <li class="mb-3 pb-3 border-bottom">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div>
                                                <strong>@incident.TriggerName</strong>
                                                <span class="badge @GetSeverityBadgeClass(incident.Severity) ms-2">@GetSeverityText(incident.Severity)</span>
                                                <br />
                                                <small class="text-muted">
                                                    Created @incident.FirstOccurrenceUtc.ToLocalTime().ToString("MMM dd, yyyy HH:mm")
                                                </small>
                                            </div>
                                            <span class="badge @GetStatusBadgeClass(incident.Status)">@incident.Status.ToString()</span>
                                        </div>
                                    </li>
                                }
                            </ul>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool isLoading = true;
    private string errorMessage = string.Empty;
    private string userName = string.Empty;

    private int activeIncidentsCount = 0;
    private int acknowledgedIncidentsCount = 0;
    private int teamsCount = 0;
    private int resolvedTodayCount = 0;

    private List<IncidentDto>? incidents;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadDashboardData();
            StateHasChanged();
        }
    }

    private async Task LoadDashboardData()
    {
        try
        {
            // Get user name from auth state
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            userName = authState.User.Identity?.Name ?? "User";

            // Load dashboard data - get open incidents
            incidents = await IncidentApi.GetOpenAsync();

            if (incidents != null)
            {
                activeIncidentsCount = incidents.Count(i => i.Status == IncidentStatus.Open);
                acknowledgedIncidentsCount = incidents.Count(i => i.Status == IncidentStatus.Acknowledged);
                resolvedTodayCount = incidents.Count(i => i.Status == IncidentStatus.Resolved);
            }

            // For teams count, we'll just set it to 0 for now since we don't have a simple GetAll method
            // This will be updated when we build the teams page
            teamsCount = 0;
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load dashboard: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private string GetSeverityBadgeClass(int severity)
    {
        // Zabbix severity levels: 0=Not classified, 1=Information, 2=Warning, 3=Average, 4=High, 5=Disaster
        return severity switch
        {
            5 => "bg-danger",        // Disaster
            4 => "bg-danger",        // High
            3 => "bg-warning text-dark", // Average
            2 => "badge-alerty",     // Warning
            1 => "bg-info",          // Information
            _ => "bg-secondary"      // Not classified
        };
    }

    private string GetSeverityText(int severity)
    {
        return severity switch
        {
            5 => "Disaster",
            4 => "High",
            3 => "Average",
            2 => "Warning",
            1 => "Information",
            _ => "Unknown"
        };
    }

    private string GetStatusBadgeClass(IncidentStatus status)
    {
        return status switch
        {
            IncidentStatus.Open => "bg-danger",
            IncidentStatus.Acknowledged => "bg-warning text-dark",
            IncidentStatus.Resolved => "bg-success",
            _ => "bg-secondary"
        };
    }

    private void NavigateToIncidents()
    {
        Navigation.NavigateTo("/incidents");
    }

    private void ViewIncident(Guid incidentId)
    {
        Navigation.NavigateTo($"/incidents/{incidentId}");
    }
}
