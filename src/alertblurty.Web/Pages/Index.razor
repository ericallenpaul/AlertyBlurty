@page "/"
@inject IOrganizationApiService OrgApi
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>AlertyBlurty</PageTitle>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            @if (isChecking)
            {
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <p class="mt-3">Checking system status...</p>
            }
            else if (error)
            {
                <div class="alert alert-danger">
                    <h4>Connection Error</h4>
                    <p>Unable to connect to the API. Please ensure the backend API is running on port 5041.</p>
                    <button class="btn btn-primary" @onclick="CheckStatus">Retry</button>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private bool isChecking = true;
    private bool error = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await CheckStatus();
            StateHasChanged();
        }
    }

    private async Task CheckStatus()
    {
        isChecking = true;
        error = false;

        try
        {
            // Check if we're authenticated
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            if (user.Identity?.IsAuthenticated == true)
            {
                // User is logged in, go to dashboard
                Navigation.NavigateTo("/dashboard", replace: true);
                return;
            }

            // Check if setup is needed
            var hasOrganizations = await OrgApi.HasOrganizationsAsync();

            if (!hasOrganizations)
            {
                // First run - go to setup wizard
                Navigation.NavigateTo("/setup", replace: true);
            }
            else
            {
                // Setup complete, go to login
                Navigation.NavigateTo("/login", replace: true);
            }
        }
        catch
        {
            error = true;
        }
        finally
        {
            isChecking = false;
        }
    }
}
