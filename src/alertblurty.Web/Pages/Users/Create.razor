@page "/users/create"
@attribute [Authorize(Roles = "SuperAdmin,Admin")]
@inject IUserApiService UserApi
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Create User - AlertyBlurty</PageTitle>

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col">
            <button class="btn btn-secondary mb-3" @onclick="NavigateBack">
                <i class="bi bi-arrow-left"></i> Back to Users
            </button>
            <h2><i class="bi bi-person-plus"></i> Create New User</h2>
            <p class="text-muted">Add a new user to your organization</p>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">User Information</h5>
                </div>
                <div class="card-body">
                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger alert-dismissible fade show">
                            <i class="bi bi-exclamation-triangle"></i> @errorMessage
                            <button type="button" class="btn-close" @onclick="() => errorMessage = string.Empty"></button>
                        </div>
                    }

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Full Name *</label>
                            <input type="text" class="form-control" @bind="fullName" placeholder="John Doe" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Email Address *</label>
                            <input type="email" class="form-control" @bind="email" placeholder="john.doe@example.com" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Phone Number *</label>
                            <input type="tel" class="form-control" @bind="phoneNumber" placeholder="+15551234567" />
                            <small class="form-text text-muted">E.164 format (e.g., +15551234567)</small>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Timezone *</label>
                            <select class="form-select" @bind="timezone">
                                <option value="America/New_York">Eastern Time (ET)</option>
                                <option value="America/Chicago">Central Time (CT)</option>
                                <option value="America/Denver">Mountain Time (MT)</option>
                                <option value="America/Los_Angeles">Pacific Time (PT)</option>
                                <option value="America/Anchorage">Alaska Time (AKT)</option>
                                <option value="Pacific/Honolulu">Hawaii Time (HST)</option>
                                <option value="UTC">UTC</option>
                                <option value="Europe/London">London (GMT/BST)</option>
                                <option value="Europe/Paris">Paris (CET/CEST)</option>
                                <option value="Asia/Tokyo">Tokyo (JST)</option>
                            </select>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Role *</label>
                            <select class="form-select" @bind="role">
                                <option value="@UserRole.User">User</option>
                                <option value="@UserRole.Admin">Admin</option>
                                <AuthorizeView Roles="SuperAdmin">
                                    <option value="@UserRole.SuperAdmin">Super Admin</option>
                                </AuthorizeView>
                            </select>
                            <small class="form-text text-muted">
                                User: Basic access | Admin: Manage teams/users | SuperAdmin: Full system access
                            </small>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Password *</label>
                            <input type="password" class="form-control" @bind="password" placeholder="Minimum 8 characters" />
                            <small class="form-text text-muted">User will be prompted to change on first login</small>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" @bind="isActive" id="isActive">
                                <label class="form-check-label" for="isActive">
                                    Account is active
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-4">
                        <button class="btn btn-secondary" @onclick="NavigateBack">
                            <i class="bi bi-x"></i> Cancel
                        </button>
                        <button class="btn btn-primary" @onclick="CreateUser" disabled="@isCreating">
                            @if (isCreating)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                                <span>Creating...</span>
                            }
                            else
                            {
                                <span><i class="bi bi-check"></i> Create User</span>
                            }
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-info-circle"></i> Information</h5>
                </div>
                <div class="card-body">
                    <h6>Password Requirements:</h6>
                    <ul class="small">
                        <li>Minimum 8 characters</li>
                        <li>At least one uppercase letter</li>
                        <li>At least one lowercase letter</li>
                        <li>At least one number</li>
                    </ul>

                    <h6 class="mt-3">User Roles:</h6>
                    <ul class="small">
                        <li><strong>User</strong>: View incidents, manage own schedule</li>
                        <li><strong>Admin</strong>: Manage users and teams</li>
                        <li><strong>SuperAdmin</strong>: Full system access</li>
                    </ul>

                    <div class="alert alert-info mt-3 mb-0 small">
                        <i class="bi bi-lightbulb"></i> The new user will be added to your organization automatically.
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private bool isCreating = false;
    private string errorMessage = string.Empty;

    private string fullName = string.Empty;
    private string email = string.Empty;
    private string phoneNumber = string.Empty;
    private string timezone = "America/New_York";
    private UserRole role = UserRole.User;
    private string password = string.Empty;
    private bool isActive = true;

    private async Task CreateUser()
    {
        // Validation
        if (string.IsNullOrWhiteSpace(fullName) ||
            string.IsNullOrWhiteSpace(email) ||
            string.IsNullOrWhiteSpace(phoneNumber) ||
            string.IsNullOrWhiteSpace(password))
        {
            errorMessage = "Please fill in all required fields";
            return;
        }

        if (password.Length < 8)
        {
            errorMessage = "Password must be at least 8 characters";
            return;
        }

        isCreating = true;
        errorMessage = string.Empty;

        try
        {
            // Get current user's organization ID
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var orgIdClaim = authState.User.FindFirst("OrganizationId");

            if (orgIdClaim == null || !Guid.TryParse(orgIdClaim.Value, out var orgId))
            {
                errorMessage = "Unable to determine your organization";
                return;
            }

            var request = new CreateUserRequest
            {
                OrganizationId = orgId,
                Email = email.Trim(),
                FullName = fullName.Trim(),
                PhoneNumber = phoneNumber.Trim(),
                Timezone = timezone,
                Role = role,
                Password = password,
                IsActive = isActive
            };

            var result = await UserApi.CreateAsync(request);

            if (result != null)
            {
                Navigation.NavigateTo("/users");
            }
            else
            {
                errorMessage = "Failed to create user";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error creating user: {ex.Message}";
        }
        finally
        {
            isCreating = false;
        }
    }

    private void NavigateBack()
    {
        Navigation.NavigateTo("/users");
    }
}
