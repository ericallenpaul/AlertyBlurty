@page "/users/{id:guid}"
@attribute [Authorize(Roles = "SuperAdmin,Admin")]
@inject IUserApiService UserApi
@inject NavigationManager Navigation

<PageTitle>User Details - AlertyBlurty</PageTitle>

<div class="container-fluid mt-4">
    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-3">Loading user details...</p>
        </div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">
            <i class="bi bi-exclamation-triangle"></i> @errorMessage
        </div>
        <button class="btn btn-secondary" @onclick="NavigateBack">
            <i class="bi bi-arrow-left"></i> Back to Users
        </button>
    }
    else if (user != null)
    {
        <!-- Header -->
        <div class="row mb-4">
            <div class="col">
                <button class="btn btn-secondary mb-3" @onclick="NavigateBack">
                    <i class="bi bi-arrow-left"></i> Back to Users
                </button>
                <h2>
                    <i class="bi bi-person"></i> @user.FullName
                    @if (user.IsActive)
                    {
                        <span class="badge bg-success ms-2">Active</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary ms-2">Inactive</span>
                    }
                </h2>
                <p class="text-muted">@user.Email</p>
            </div>
            <div class="col-auto">
                <AuthorizeView Roles="SuperAdmin">
                    <button class="btn btn-outline-danger" @onclick="DeleteUser" disabled="@isDeleting">
                        @if (isDeleting)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                            <span>Deleting...</span>
                        }
                        else
                        {
                            <span><i class="bi bi-trash"></i> Delete User</span>
                        }
                    </button>
                </AuthorizeView>
            </div>
        </div>

        <div class="row">
            <!-- Left Column: User Info -->
            <div class="col-lg-8">
                <!-- Basic Information -->
                <div class="card shadow mb-4">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">Basic Information</h5>
                    </div>
                    <div class="card-body">
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="text-muted small">Full Name</label>
                                <p class="mb-0"><strong>@user.FullName</strong></p>
                            </div>
                            <div class="col-md-6">
                                <label class="text-muted small">Email Address</label>
                                <p class="mb-0">@user.Email</p>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="text-muted small">Phone Number</label>
                                <p class="mb-0">@user.PhoneNumber</p>
                            </div>
                            <div class="col-md-6">
                                <label class="text-muted small">Timezone</label>
                                <p class="mb-0">@user.Timezone</p>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="text-muted small">Role</label>
                                <p class="mb-0">
                                    <span class="badge @GetRoleBadgeClass(user.Role)">
                                        @user.Role
                                    </span>
                                </p>
                            </div>
                            <div class="col-md-6">
                                <label class="text-muted small">Account Status</label>
                                <p class="mb-0">
                                    @if (user.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactive</span>
                                    }
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Edit User Form -->
                <div class="card shadow">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">Edit User</h5>
                    </div>
                    <div class="card-body">
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label">Full Name</label>
                                <input type="text" class="form-control" @bind="editFullName" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Phone Number</label>
                                <input type="tel" class="form-control" @bind="editPhoneNumber" />
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label">Timezone</label>
                                <select class="form-select" @bind="editTimezone">
                                    <option value="America/New_York">Eastern Time</option>
                                    <option value="America/Chicago">Central Time</option>
                                    <option value="America/Denver">Mountain Time</option>
                                    <option value="America/Los_Angeles">Pacific Time</option>
                                    <option value="UTC">UTC</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Status</label>
                                <select class="form-select" @bind="editIsActive">
                                    <option value="true">Active</option>
                                    <option value="false">Inactive</option>
                                </select>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-2">
                            <button class="btn btn-secondary" @onclick="ResetForm">
                                <i class="bi bi-x"></i> Reset
                            </button>
                            <button class="btn btn-primary" @onclick="UpdateUser" disabled="@isUpdating">
                                @if (isUpdating)
                                {
                                    <span class="spinner-border spinner-border-sm me-2"></span>
                                    <span>Updating...</span>
                                }
                                else
                                {
                                    <span><i class="bi bi-save"></i> Save Changes</span>
                                }
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Column: Additional Info -->
            <div class="col-lg-4">
                <!-- Account Details -->
                <div class="card shadow mb-4">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">Account Details</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="text-muted small">User ID</label>
                            <p class="mb-0"><code>@user.Id</code></p>
                        </div>
                        <div class="mb-3">
                            <label class="text-muted small">Organization</label>
                            <p class="mb-0">@user.OrganizationName</p>
                        </div>
                        <div class="mb-3">
                            <label class="text-muted small">Created At</label>
                            <p class="mb-0">@user.CreatedAtUtc.ToLocalTime().ToString("MMM dd, yyyy HH:mm")</p>
                        </div>
                        <div>
                            <label class="text-muted small">Last Updated</label>
                            <p class="mb-0">@(user.UpdatedAtUtc?.ToLocalTime().ToString("MMM dd, yyyy HH:mm") ?? "Never")</p>
                        </div>
                    </div>
                </div>

                <!-- Role Information -->
                <div class="card shadow">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">Role Permissions</h5>
                    </div>
                    <div class="card-body">
                        @if (user.Role == UserRole.SuperAdmin)
                        {
                            <div class="alert alert-danger mb-0">
                                <strong>Super Administrator</strong>
                                <ul class="mt-2 mb-0">
                                    <li>Full system access</li>
                                    <li>Manage all users</li>
                                    <li>Manage all teams</li>
                                    <li>System configuration</li>
                                </ul>
                            </div>
                        }
                        else if (user.Role == UserRole.Admin)
                        {
                            <div class="alert alert-warning mb-0">
                                <strong>Administrator</strong>
                                <ul class="mt-2 mb-0">
                                    <li>Manage users</li>
                                    <li>Manage teams</li>
                                    <li>View all incidents</li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-info mb-0">
                                <strong>User</strong>
                                <ul class="mt-2 mb-0">
                                    <li>View incidents</li>
                                    <li>Manage own schedule</li>
                                    <li>Team member access</li>
                                </ul>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="alert alert-success alert-dismissible fade show mt-3">
            <i class="bi bi-check-circle"></i> @successMessage
            <button type="button" class="btn-close" @onclick="() => successMessage = string.Empty"></button>
        </div>
    }
</div>

@code {
    [Parameter]
    public Guid Id { get; set; }

    private bool isLoading = true;
    private bool isUpdating = false;
    private bool isDeleting = false;
    private string errorMessage = string.Empty;
    private string successMessage = string.Empty;

    private UserDto? user;

    // Edit form fields
    private string editFullName = string.Empty;
    private string editPhoneNumber = string.Empty;
    private string editTimezone = string.Empty;
    private string editIsActive = "true";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadUser();
            StateHasChanged();
        }
    }

    private async Task LoadUser()
    {
        try
        {
            user = await UserApi.GetByIdAsync(Id);
            if (user == null)
            {
                errorMessage = "User not found";
                return;
            }

            // Initialize edit form
            ResetForm();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load user: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ResetForm()
    {
        if (user != null)
        {
            editFullName = user.FullName;
            editPhoneNumber = user.PhoneNumber;
            editTimezone = user.Timezone;
            editIsActive = user.IsActive.ToString().ToLower();
        }
    }

    private async Task UpdateUser()
    {
        if (string.IsNullOrWhiteSpace(editFullName) || string.IsNullOrWhiteSpace(editPhoneNumber))
        {
            errorMessage = "Please fill in all required fields";
            return;
        }

        isUpdating = true;
        errorMessage = string.Empty;

        try
        {
            var request = new alertblurty.Models.Requests.Users.UpdateUserRequest
            {
                FullName = editFullName,
                PhoneNumber = editPhoneNumber,
                Timezone = editTimezone,
                IsActive = bool.Parse(editIsActive)
            };

            var result = await UserApi.UpdateAsync(Id, request);

            if (result != null)
            {
                user = result;
                successMessage = "User updated successfully!";
                ResetForm();
            }
            else
            {
                errorMessage = "Failed to update user";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error updating user: {ex.Message}";
        }
        finally
        {
            isUpdating = false;
        }
    }

    private async Task DeleteUser()
    {
        isDeleting = true;
        errorMessage = string.Empty;

        try
        {
            var success = await UserApi.DeleteAsync(Id);

            if (success)
            {
                Navigation.NavigateTo("/users");
            }
            else
            {
                errorMessage = "Failed to delete user";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error deleting user: {ex.Message}";
        }
        finally
        {
            isDeleting = false;
        }
    }

    private string GetRoleBadgeClass(UserRole role)
    {
        return role switch
        {
            UserRole.SuperAdmin => "badge-alerty-red",
            UserRole.Admin => "badge-alerty",
            UserRole.User => "bg-info",
            _ => "bg-secondary"
        };
    }

    private void NavigateBack()
    {
        Navigation.NavigateTo("/users");
    }
}
