@page "/incidents"
@attribute [Authorize]
@inject IIncidentApiService IncidentApi
@inject NavigationManager Navigation

<PageTitle>Incidents - AlertyBlurty</PageTitle>

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col">
            <h2><i class="bi bi-exclamation-triangle"></i> Incidents</h2>
            <p class="text-muted">View and manage active incidents</p>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-3">Loading incidents...</p>
        </div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">
            <i class="bi bi-exclamation-triangle"></i> @errorMessage
        </div>
    }
    else
    {
        <!-- Filter Tabs -->
        <div class="card shadow mb-4">
            <div class="card-body">
                <ul class="nav nav-tabs" role="tablist">
                    <li class="nav-item">
                        <a class="nav-link @(statusFilter == IncidentStatus.Open ? "active" : "")"
                           @onclick="() => FilterByStatus(IncidentStatus.Open)"
                           style="cursor: pointer;">
                            <i class="bi bi-exclamation-circle"></i> Open (@openCount)
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(statusFilter == IncidentStatus.Acknowledged ? "active" : "")"
                           @onclick="() => FilterByStatus(IncidentStatus.Acknowledged)"
                           style="cursor: pointer;">
                            <i class="bi bi-check-circle"></i> Acknowledged (@acknowledgedCount)
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(statusFilter == IncidentStatus.Resolved ? "active" : "")"
                           @onclick="() => FilterByStatus(IncidentStatus.Resolved)"
                           style="cursor: pointer;">
                            <i class="bi bi-check2-circle"></i> Resolved (@resolvedCount)
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(statusFilter == null ? "active" : "")"
                           @onclick="() => FilterByStatus(null)"
                           style="cursor: pointer;">
                            <i class="bi bi-list"></i> All (@(incidents?.Count ?? 0))
                        </a>
                    </li>
                </ul>
            </div>
        </div>

        <!-- Incidents Table -->
        <div class="card shadow">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">
                    @if (statusFilter != null)
                    {
                        <span>@statusFilter.ToString() Incidents</span>
                    }
                    else
                    {
                        <span>All Incidents</span>
                    }
                </h5>
            </div>
            <div class="card-body">
                @if (filteredIncidents == null || !filteredIncidents.Any())
                {
                    <div class="text-center py-4">
                        <i class="bi bi-inbox text-muted" style="font-size: 3rem;"></i>
                        <p class="mt-3 text-muted">No incidents found</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Severity</th>
                                    <th>Trigger</th>
                                    <th>Host</th>
                                    <th>Status</th>
                                    <th>Team</th>
                                    <th>First Occurrence</th>
                                    <th>Last Occurrence</th>
                                    <th>Count</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var incident in filteredIncidents)
                                {
                                    <tr style="cursor: pointer;" @onclick="() => ViewIncident(incident.Id)">
                                        <td>
                                            <span class="badge @GetSeverityBadgeClass(incident.Severity)">
                                                @GetSeverityText(incident.Severity)
                                            </span>
                                        </td>
                                        <td>
                                            <strong>@incident.TriggerName</strong>
                                            @if (!string.IsNullOrEmpty(incident.TriggerDescription))
                                            {
                                                <br />
                                                <small class="text-muted">@incident.TriggerDescription</small>
                                            }
                                        </td>
                                        <td>@incident.HostName</td>
                                        <td>
                                            <span class="badge @GetStatusBadgeClass(incident.Status)">
                                                @incident.Status.ToString()
                                            </span>
                                        </td>
                                        <td>@incident.TeamName</td>
                                        <td>@incident.FirstOccurrenceUtc.ToLocalTime().ToString("MMM dd, HH:mm")</td>
                                        <td>@incident.LastOccurrenceUtc.ToLocalTime().ToString("MMM dd, HH:mm")</td>
                                        <td>
                                            <span class="badge bg-secondary">@incident.EventCount</span>
                                        </td>
                                        <td>
                                            @if (incident.Status == IncidentStatus.Open)
                                            {
                                                <button class="btn btn-sm btn-warning"
                                                        @onclick="() => AcknowledgeIncident(incident.Id)"
                                                        @onclick:stopPropagation="true">
                                                    <i class="bi bi-check"></i> Ack
                                                </button>
                                            }
                                            else
                                            {
                                                <button class="btn btn-sm btn-outline-primary"
                                                        @onclick="() => ViewIncident(incident.Id)"
                                                        @onclick:stopPropagation="true">
                                                    <i class="bi bi-eye"></i> View
                                                </button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    private bool isLoading = true;
    private string errorMessage = string.Empty;
    private List<IncidentDto>? incidents;
    private List<IncidentDto>? filteredIncidents;
    private IncidentStatus? statusFilter = IncidentStatus.Open;

    private int openCount = 0;
    private int acknowledgedCount = 0;
    private int resolvedCount = 0;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadIncidents();
            StateHasChanged();
        }
    }

    private async Task LoadIncidents()
    {
        try
        {
            incidents = await IncidentApi.GetOpenAsync();

            if (incidents != null)
            {
                openCount = incidents.Count(i => i.Status == IncidentStatus.Open);
                acknowledgedCount = incidents.Count(i => i.Status == IncidentStatus.Acknowledged);
                resolvedCount = incidents.Count(i => i.Status == IncidentStatus.Resolved);

                ApplyFilter();
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load incidents: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void FilterByStatus(IncidentStatus? status)
    {
        statusFilter = status;
        ApplyFilter();
    }

    private void ApplyFilter()
    {
        if (incidents == null)
        {
            filteredIncidents = null;
            return;
        }

        if (statusFilter == null)
        {
            filteredIncidents = incidents;
        }
        else
        {
            filteredIncidents = incidents.Where(i => i.Status == statusFilter).ToList();
        }
    }

    private string GetSeverityBadgeClass(int severity)
    {
        return severity switch
        {
            5 => "bg-danger",
            4 => "bg-danger",
            3 => "bg-warning text-dark",
            2 => "badge-alerty",
            1 => "bg-info",
            _ => "bg-secondary"
        };
    }

    private string GetSeverityText(int severity)
    {
        return severity switch
        {
            5 => "Disaster",
            4 => "High",
            3 => "Average",
            2 => "Warning",
            1 => "Information",
            _ => "Unknown"
        };
    }

    private string GetStatusBadgeClass(IncidentStatus status)
    {
        return status switch
        {
            IncidentStatus.Open => "bg-danger text-white",
            IncidentStatus.Acknowledged => "bg-warning text-dark",
            IncidentStatus.Resolved => "bg-success text-white",
            _ => "bg-secondary text-white"
        };
    }

    private void ViewIncident(Guid incidentId)
    {
        Navigation.NavigateTo($"/incidents/{incidentId}");
    }

    private async Task AcknowledgeIncident(Guid incidentId)
    {
        try
        {
            var result = await IncidentApi.AcknowledgeAsync(incidentId);
            if (result != null)
            {
                // Reload incidents
                await LoadIncidents();
            }
            else
            {
                errorMessage = "Failed to acknowledge incident";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error acknowledging incident: {ex.Message}";
        }
    }
}
