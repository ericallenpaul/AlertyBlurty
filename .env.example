ALERTYBLURTY_IMAGE=ericallenpaul/alertyblurty:latest
ALERTYBLURTY_PORT=8080
ALERTYBLURTY_CONFIG_PATH=/app/data/appsettings.Local.json

POSTGRES_DB=alertyblurty
POSTGRES_USER=alerty_app
POSTGRES_PASSWORD=change-this-postgres-password

# Optional env-var startup override. Leave blank to use the first-run wizard.
CONNECTION_STRING=
JWT_SECRET=
JWT_ISSUER=AlertyBlurty
JWT_AUDIENCE=AlertyBlurty
JWT_EXPIRY_HOURS=24
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
